#!/usr/bin/env bash
set -eu

#MISE description="Add utm-dev tools and env to your project's mise.toml"
#MISE alias="i"

# Adds the [tools] and [env] blocks needed for Tauri cross-platform builds.
# Idempotent — safe to run multiple times.
# Handles existing [tools]/[env] sections by merging, not duplicating.

MISE_TOML="$(pwd)/mise.toml"

if [ ! -f "${MISE_TOML}" ]; then
  echo "✗ No mise.toml found in $(pwd)"
  echo "  Create one first, or run from your project root."
  exit 1
fi

# Check if we already added our blocks
if grep -q "# utm-dev tools" "${MISE_TOML}" 2>/dev/null; then
  echo "✓ Already initialised"
  exit 0
fi

# Check for existing [tools] or [env] sections
HAS_TOOLS=$(grep -c '^\[tools\]' "${MISE_TOML}" 2>/dev/null || echo 0)
HAS_ENV=$(grep -c '^\[env\]' "${MISE_TOML}" 2>/dev/null || echo 0)

if [ "${HAS_TOOLS}" -gt 0 ] || [ "${HAS_ENV}" -gt 0 ]; then
  echo "⚠ Your mise.toml already has [tools] and/or [env] sections."
  echo "  Add the following lines manually to your existing sections:"
  echo ""
  if [ "${HAS_TOOLS}" -gt 0 ]; then
    echo '  # In your [tools] section:'
    echo '  "cargo:tauri-cli" = {version = "2",      os = ["macos", "windows"]}'
    echo '  xcodegen          = {version = "latest", os = ["macos"]}'
    echo '  ruby              = {version = "3.3",    os = ["macos"]}'
    echo '  java              = "temurin-17.0.18+8"'
    echo ""
  fi
  if [ "${HAS_ENV}" -gt 0 ]; then
    echo '  # In your [env] section:'
    echo '  ANDROID_HOME = "{{env.HOME}}/.android-sdk"'
    echo '  NDK_HOME = "{{env.HOME}}/.android-sdk/ndk/27.2.12479018"'
    echo '  JAVA_HOME = "{{env.HOME}}/.local/share/mise/installs/java/temurin-17.0.18+8"'
    echo ""
  fi
  exit 0
fi

cat >> "${MISE_TOML}" <<'TOMLEOF'

# utm-dev tools — added by mise run init
[tools]
"cargo:tauri-cli" = {version = "2",      os = ["macos", "windows"]}
xcodegen          = {version = "latest", os = ["macos"]}
ruby              = {version = "3.3",    os = ["macos"]}
java              = "temurin-17.0.18+8"

# utm-dev env — Android SDK paths (installed by mise run setup)
[env]
ANDROID_HOME = "{{env.HOME}}/.android-sdk"
NDK_HOME = "{{env.HOME}}/.android-sdk/ndk/27.2.12479018"
JAVA_HOME = "{{env.HOME}}/.local/share/mise/installs/java/temurin-17.0.18+8"
TOMLEOF

echo "✓ Added [tools] and [env] to ${MISE_TOML}"
echo ""
echo "Next:"
echo "  mise install      # Install tools"
echo "  mise run setup    # Install SDKs"
