#!/usr/bin/env bash
set -eu

#MISE description="Stop the Windows VM"
#MISE alias="vm-down"

PROJECT_DIR="$(pwd)"
LOGDIR="${PROJECT_DIR}/.mise/logs"
STATEFILE="${PROJECT_DIR}/.mise/state/vm.env"
UTMCTL="/Applications/UTM.app/Contents/MacOS/utmctl"

mkdir -p "${LOGDIR}"
exec > >(tee -a "${LOGDIR}/vm-down.log") 2>&1
echo "── $(date '+%Y-%m-%d %H:%M:%S') ──"

[ -x "${UTMCTL}" ] || { echo "✗ UTM not installed"; exit 1; }
[ -f "${STATEFILE}" ] || { echo "✗ No VM state — run mise vm:up first"; exit 1; }
source "${STATEFILE}"
[ -z "${VM_UUID:-}" ] && { echo "✗ No VM UUID in state"; exit 1; }

VM_STATUS=$(${UTMCTL} list 2>/dev/null | awk -v id="${VM_UUID}" '$1==id {print $2}')

case "${VM_STATUS}" in
  started)
    echo "→ Stopping '${VM_DISPLAY_NAME}'..."
    ${UTMCTL} stop "${VM_DISPLAY_NAME}"
    echo "✓ Stopped"
    ;;
  stopped)
    echo "✓ Already stopped"
    ;;
  *)
    echo "✗ VM not found (UUID: ${VM_UUID})"
    exit 1
    ;;
esac
