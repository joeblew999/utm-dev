#!/usr/bin/env bash
set -eu

#MISE description="Run a command inside the Windows VM via SSH"
#MISE alias="vm-exec"

PROJECT_DIR="$(pwd)"
LOGDIR="${PROJECT_DIR}/.mise/logs"
mkdir -p "${LOGDIR}"
exec > >(tee -a "${LOGDIR}/vm-exec.log") 2>&1
echo "── $(date '+%Y-%m-%d %H:%M:%S') ──"

SSH_PORT=2222
VM_USER="vagrant"
VM_PASS="vagrant"

if [ $# -eq 0 ]; then
  echo "Usage: mise vm:exec <command>"
  echo "  mise vm:exec 'whoami'"
  echo "  mise vm:exec 'cargo --version'"
  exit 1
fi

# Ensure sshpass is available
if ! command -v sshpass >/dev/null 2>&1; then
  echo "→ Installing sshpass..."
  HOMEBREW_NO_AUTO_UPDATE=1 brew install hudochenkov/sshpass/sshpass </dev/null 2>/dev/null \
    || { echo "✗ Failed to install sshpass"; exit 1; }
fi

if ! sshpass -p "${VM_PASS}" ssh -o ConnectTimeout=3 -o StrictHostKeyChecking=no -p ${SSH_PORT} ${VM_USER}@127.0.0.1 "echo" 2>/dev/null; then
  echo "✗ Cannot connect via SSH (port ${SSH_PORT})"
  echo "  VM running?       mise run vm:up"
  echo "  SSH bootstrapped?  mise run vm:bootstrap"
  exit 1
fi

echo "→ $*"
sshpass -p "${VM_PASS}" ssh -o StrictHostKeyChecking=no -p ${SSH_PORT} ${VM_USER}@127.0.0.1 "$*"
