#!/usr/bin/env bash
set -eu

#MISE description="Bootstrap Windows VM: SSH, mise, VS Build Tools, WebView2"
#MISE alias="vm-bootstrap"

# Bootstraps the Windows VM via WinRM (the only thing available on a fresh box).
# Installs: OpenSSH Server, VS Build Tools, WebView2, mise (which handles Rust + cargo-tauri).
# Idempotent — safe to run multiple times.
# Requires: python3, pywinrm (auto-installed)

PROJECT_DIR="$(pwd)"
LOGDIR="${PROJECT_DIR}/.mise/logs"
mkdir -p "${LOGDIR}"
exec > >(tee -a "${LOGDIR}/vm-bootstrap.log") 2>&1
echo "── $(date '+%Y-%m-%d %H:%M:%S') ──"

WINRM_PORT=5985
SSH_PORT=2222
VM_USER="vagrant"
VM_PASS="vagrant"

die()  { echo "✗ $*" >&2; exit 1; }
info() { echo "→ $*"; }
ok()   { echo "✓ $*"; }

# ── Check WinRM is reachable ─────────────────────────────────────────────────

curl -s --connect-timeout 3 "http://127.0.0.1:${WINRM_PORT}/wsman" >/dev/null 2>&1 \
  || die "WinRM not reachable on port ${WINRM_PORT} — is the VM running?"

# ── Ensure pywinrm is installed ──────────────────────────────────────────────

if ! python3 -c "import winrm" 2>/dev/null; then
  info "Installing pywinrm..."
  pip3 install --quiet pywinrm 2>/dev/null || pip3 install --quiet --user pywinrm
  ok "pywinrm installed"
fi

# ── Run bootstrap via WinRM ──────────────────────────────────────────────────

info "Bootstrapping Windows VM via WinRM..."

python3 << 'PYEOF'
import winrm, sys, time, warnings
warnings.filterwarnings("ignore")

s = winrm.Session('http://127.0.0.1:5985/wsman', auth=('vagrant', 'vagrant'), transport='basic',
                   read_timeout_sec=600, operation_timeout_sec=540)

def run_elevated(ps_code, desc, timeout=120):
    """Run PowerShell as SYSTEM via scheduled task (bypasses UAC)."""
    print(f"→ {desc}")
    r = s.run_ps(f'@\'\n{ps_code}\n\'@ | Set-Content "C:\\bootstrap-step.ps1" -Force')
    if r.status_code != 0:
        print(f"  ERR writing script: {r.std_err.decode().strip()[:200]}")
        return False

    r = s.run_ps('''
$action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -File C:\\bootstrap-step.ps1"
$principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -RunLevel Highest
Register-ScheduledTask -TaskName "BootstrapStep" -Action $action -Principal $principal -Force | Out-Null
Start-ScheduledTask -TaskName "BootstrapStep"
''')

    for i in range(timeout // 5):
        time.sleep(5)
        r = s.run_ps('(Get-ScheduledTask -TaskName "BootstrapStep" -ErrorAction SilentlyContinue).State')
        state = r.std_out.decode().strip()
        if state != "Running":
            break
        if (i * 5) % 30 == 0 and i > 0:
            print(f"  still running... ({i*5}s)")

    s.run_ps('Unregister-ScheduledTask -TaskName "BootstrapStep" -Confirm:$false -ErrorAction SilentlyContinue')
    s.run_ps('Remove-Item "C:\\bootstrap-step.ps1" -Force -ErrorAction SilentlyContinue')
    return True

def check(desc, ps_check):
    r = s.run_ps(ps_check)
    val = r.std_out.decode().strip()
    if val:
        print(f"✓ {desc}: {val}")
        return True
    return False

def winget_install(pkg_id, desc, timeout=300):
    """Install a package via winget as SYSTEM."""
    if check(desc, f'winget list --id {pkg_id} --accept-source-agreements 2>$null | Select-String "{pkg_id}"'):
        return True
    run_elevated(
        f'winget install --id {pkg_id} --accept-source-agreements --accept-package-agreements --silent',
        f"Installing {desc} via winget...",
        timeout=timeout
    )
    return True

# ── Step 1: OpenSSH Server ───────────────────────────────────────────────────

if not check("OpenSSH", 'Get-Service sshd -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Status'):
    run_elevated(
        'Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0',
        "Installing OpenSSH Server...",
        timeout=300
    )

# Configure sshd for password auth
run_elevated(r'''
$configPath = "C:\ProgramData\ssh\sshd_config"
$content = Get-Content $configPath
$newContent = @()
foreach ($line in $content) {
    if ($line -match "^#PasswordAuthentication yes") {
        $newContent += "PasswordAuthentication yes"
    } elseif ($line -match "^Match Group administrators") {
        $newContent += "#Match Group administrators"
    } elseif ($line -match "AuthorizedKeysFile __PROGRAMDATA__") {
        $newContent += "#AuthorizedKeysFile __PROGRAMDATA__/ssh/administrators_authorized_keys"
    } else {
        $newContent += $line
    }
}
$newContent | Set-Content $configPath -Force
Start-Service sshd -ErrorAction SilentlyContinue
Set-Service -Name sshd -StartupType Automatic
Restart-Service sshd
''', "Configuring SSH...")

r = s.run_ps('Get-Service sshd | Select-Object -ExpandProperty Status')
status = r.std_out.decode().strip()
if status != "Running":
    print(f"✗ sshd: {status}")
    sys.exit(1)
print(f"✓ sshd: {status}")

# ── Step 2: VS Build Tools (needed for Rust/MSVC on Windows) ────────────────

winget_install(
    "Microsoft.VisualStudio.2022.BuildTools",
    "VS Build Tools 2022",
    timeout=600
)

# Install the C++ workload (needed by Rust)
run_elevated(r'''
$vs = & "C:\Program Files (x86)\Microsoft Visual Studio\Installer\vswhere.exe" -latest -property installationPath 2>$null
if (-not $vs) { $vs = "C:\Program Files\Microsoft Visual Studio\2022\BuildTools" }
$installer = "C:\Program Files (x86)\Microsoft Visual Studio\Installer\vs_installer.exe"
if (Test-Path $installer) {
    Start-Process -FilePath $installer -ArgumentList "modify","--installPath",$vs,"--add","Microsoft.VisualStudio.Workload.VCTools","--includeRecommended","--quiet","--norestart" -Wait -NoNewWindow
}
''', "Installing C++ workload for MSVC...", timeout=600)

# ── Step 3: WebView2 Runtime (needed by Tauri) ─────────────────────────────

winget_install(
    "Microsoft.EdgeWebView2Runtime",
    "WebView2 Runtime",
    timeout=120
)

# ── Step 4: mise (handles Rust + cargo-tauri) ──────────────────────────────

r = s.run_cmd('where mise')
if r.status_code == 0:
    r2 = s.run_cmd('mise --version')
    print(f"✓ mise: {r2.std_out.decode().strip()}")
else:
    print("→ Installing mise...")
    r = s.run_ps('winget install --id jdx.mise --accept-source-agreements --accept-package-agreements --silent')
    if r.status_code == 0:
        print("✓ mise installed")
    else:
        # Fallback: install via PowerShell
        r = s.run_ps('Invoke-Expression (Invoke-WebRequest -Uri "https://mise.run" -UseBasicParsing).Content')
        print(f"  mise install: exit {r.status_code}")

print()
print("✓ Bootstrap complete")
print("  Next: mise run vm:sync && mise run vm:exec 'cd project && mise install'")
PYEOF
