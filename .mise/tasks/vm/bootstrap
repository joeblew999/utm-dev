#!/usr/bin/env bash
set -eu

#MISE description="Bootstrap Windows VM: enable SSH, install Rust + cargo-tauri"
#MISE alias="vm-bootstrap"

# Bootstraps the Windows VM via WinRM (the only thing available on a fresh box).
# Installs OpenSSH Server, enables password auth, installs Rust + cargo-tauri.
# Idempotent — safe to run multiple times.
# Requires: python3, pywinrm (pip3 install pywinrm)

PROJECT_DIR="$(pwd)"
LOGDIR="${PROJECT_DIR}/.mise/logs"
mkdir -p "${LOGDIR}"
exec > >(tee -a "${LOGDIR}/vm-bootstrap.log") 2>&1
echo "── $(date '+%Y-%m-%d %H:%M:%S') ──"

WINRM_PORT=5985
SSH_PORT=2222
VM_USER="vagrant"
VM_PASS="vagrant"

die()  { echo "✗ $*" >&2; exit 1; }
info() { echo "→ $*"; }
ok()   { echo "✓ $*"; }

# ── Check WinRM is reachable ─────────────────────────────────────────────────

curl -s --connect-timeout 3 "http://127.0.0.1:${WINRM_PORT}/wsman" >/dev/null 2>&1 \
  || die "WinRM not reachable on port ${WINRM_PORT} — is the VM running? (mise run vm:up)"

# ── Ensure pywinrm is installed ──────────────────────────────────────────────

if ! python3 -c "import winrm" 2>/dev/null; then
  info "Installing pywinrm..."
  pip3 install --quiet pywinrm 2>/dev/null || pip3 install --quiet --user pywinrm
  ok "pywinrm installed"
fi

# ── Check if already bootstrapped (SSH works) ────────────────────────────────

if command -v sshpass >/dev/null 2>&1; then
  if sshpass -p "${VM_PASS}" ssh -o ConnectTimeout=3 -o StrictHostKeyChecking=no -p ${SSH_PORT} ${VM_USER}@127.0.0.1 "echo ok" 2>/dev/null | grep -q ok; then
    ok "SSH already working"
    # Check if Rust is installed
    if sshpass -p "${VM_PASS}" ssh -o StrictHostKeyChecking=no -p ${SSH_PORT} ${VM_USER}@127.0.0.1 "cargo --version" 2>/dev/null | grep -q cargo; then
      ok "Rust already installed"
      ok "Bootstrap complete (already done)"
      exit 0
    fi
  fi
fi

# ── Install and configure OpenSSH via WinRM ──────────────────────────────────

info "Bootstrapping Windows VM via WinRM..."

python3 << 'PYEOF'
import winrm, sys, time

s = winrm.Session('http://127.0.0.1:5985/wsman', auth=('vagrant', 'vagrant'), transport='basic',
                   read_timeout_sec=600, operation_timeout_sec=540)

def run_elevated(ps_code, desc, timeout=60):
    """Run PowerShell as SYSTEM via scheduled task (bypasses UAC)."""
    print(f"→ {desc}")
    # Write script to file
    r = s.run_ps(f'@\'\n{ps_code}\n\'@ | Set-Content "C:\\bootstrap-step.ps1" -Force')
    if r.status_code != 0:
        err = r.std_err.decode().strip()
        print(f"  ERR writing script: {err[:200]}")
        return False

    # Run as SYSTEM
    r = s.run_ps('''
$action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -File C:\\bootstrap-step.ps1"
$principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -RunLevel Highest
Register-ScheduledTask -TaskName "BootstrapStep" -Action $action -Principal $principal -Force | Out-Null
Start-ScheduledTask -TaskName "BootstrapStep"
''')

    # Wait for completion
    for i in range(timeout // 5):
        time.sleep(5)
        r = s.run_ps('(Get-ScheduledTask -TaskName "BootstrapStep" -ErrorAction SilentlyContinue).State')
        state = r.std_out.decode().strip()
        if state != "Running":
            break
        if (i * 5) % 30 == 0 and i > 0:
            print(f"  still running... ({i*5}s)")

    # Cleanup
    s.run_ps('Unregister-ScheduledTask -TaskName "BootstrapStep" -Confirm:$false -ErrorAction SilentlyContinue')
    s.run_ps('Remove-Item "C:\\bootstrap-step.ps1" -Force -ErrorAction SilentlyContinue')
    return True

def check(desc, ps_check):
    r = s.run_ps(ps_check)
    val = r.std_out.decode().strip()
    if val:
        print(f"✓ {desc}: {val}")
        return True
    return False

# ── Step 1: Install OpenSSH Server ───────────────────────────────────────────

if not check("OpenSSH Server", 'Get-Service sshd -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Status'):
    run_elevated(
        'Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0',
        "Installing OpenSSH Server (downloading from Windows Update)...",
        timeout=300
    )

# ── Step 2: Configure sshd for password auth ────────────────────────────────

run_elevated(r'''
$configPath = "C:\ProgramData\ssh\sshd_config"
$content = Get-Content $configPath
$newContent = @()
foreach ($line in $content) {
    if ($line -match "^#PasswordAuthentication yes") {
        $newContent += "PasswordAuthentication yes"
    } elseif ($line -match "^Match Group administrators") {
        $newContent += "#Match Group administrators"
    } elseif ($line -match "AuthorizedKeysFile __PROGRAMDATA__") {
        $newContent += "#AuthorizedKeysFile __PROGRAMDATA__/ssh/administrators_authorized_keys"
    } else {
        $newContent += $line
    }
}
$newContent | Set-Content $configPath -Force
Start-Service sshd -ErrorAction SilentlyContinue
Set-Service -Name sshd -StartupType Automatic
Restart-Service sshd
''', "Configuring SSH for password auth + auto-start")

# Verify SSH
r = s.run_ps('Get-Service sshd | Select-Object -ExpandProperty Status')
status = r.std_out.decode().strip()
if status == "Running":
    print(f"✓ sshd: {status}")
else:
    print(f"✗ sshd not running: {status}")
    sys.exit(1)

# ── Step 3: Install Rust ────────────────────────────────────────────────────

r = s.run_cmd('where cargo')
if r.status_code == 0:
    r2 = s.run_cmd('cargo --version')
    print(f"✓ Rust: {r2.std_out.decode().strip()}")
else:
    # Install Rust via rustup (as vagrant user, not SYSTEM)
    print("→ Installing Rust (this takes a few minutes)...")
    r = s.run_ps('Invoke-WebRequest -Uri "https://win.rustup.rs/aarch64" -OutFile "$env:TEMP\\rustup-init.exe"')
    if r.status_code != 0:
        print(f"  ERR downloading rustup: {r.std_err.decode().strip()[:200]}")
        sys.exit(1)

    r = s.run_cmd(f'%TEMP%\\rustup-init.exe -y --default-toolchain stable')
    out = r.std_out.decode().strip()
    err = r.std_err.decode().strip()
    if "installed" in out.lower() or "unchanged" in out.lower() or r.status_code == 0:
        print("✓ Rust installed")
    else:
        print(f"  out: {out[:200]}")
        if err: print(f"  err: {err[:200]}")

# ── Step 4: Install cargo-tauri ─────────────────────────────────────────────

r = s.run_cmd('%USERPROFILE%\\.cargo\\bin\\cargo.exe tauri --version')
if r.status_code == 0:
    print(f"✓ cargo-tauri: {r.std_out.decode().strip()}")
else:
    print("→ Installing cargo-tauri (this takes a few minutes)...")
    r = s.run_cmd('%USERPROFILE%\\.cargo\\bin\\cargo.exe install tauri-cli')
    if r.status_code == 0:
        print("✓ cargo-tauri installed")
    else:
        print(f"  ERR: {r.std_err.decode().strip()[:300]}")

print()
print("✓ Bootstrap complete")
PYEOF
