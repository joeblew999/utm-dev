#!/usr/bin/env bash
set -eu

#MISE description="Build Tauri Windows app: sync code to VM, build, pull artifacts back"
#MISE alias="vm-build"

PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "${PROJECT_DIR}")"
LOGDIR="${PROJECT_DIR}/.mise/logs"
mkdir -p "${LOGDIR}"
exec > >(tee -a "${LOGDIR}/vm-build.log") 2>&1
echo "── $(date '+%Y-%m-%d %H:%M:%S') ──"

SSH_PORT=2222
VM_USER="vagrant"
VM_PASS="vagrant"
VM_PROJECT_DIR="C:\\Users\\${VM_USER}\\${PROJECT_NAME}"
ARTIFACTS_DIR="${PROJECT_DIR}/.build/windows"

die()  { echo "✗ $*" >&2; exit 1; }
info() { echo "→ $*"; }
ok()   { echo "✓ $*"; }

# Ensure sshpass
if ! command -v sshpass >/dev/null 2>&1; then
  info "Installing sshpass..."
  HOMEBREW_NO_AUTO_UPDATE=1 brew install hudochenkov/sshpass/sshpass </dev/null 2>/dev/null
fi

SSH_CMD="sshpass -p ${VM_PASS} ssh -o StrictHostKeyChecking=no -p ${SSH_PORT} ${VM_USER}@127.0.0.1"
SCP_CMD="sshpass -p ${VM_PASS} scp -o StrictHostKeyChecking=no -P ${SSH_PORT}"

# Test connection
${SSH_CMD} "echo ok" 2>/dev/null | grep -q ok || die "Cannot connect via SSH. Run: mise run vm:up"

# ── Step 1: Sync code ────────────────────────────────────────────────────────

info "Syncing project to VM..."
TMPTAR=$(mktemp /tmp/vm-build-XXXXX.tar.gz)
trap "rm -f ${TMPTAR}" EXIT

tar -czf "${TMPTAR}" \
  --exclude='target' \
  --exclude='node_modules' \
  --exclude='.git' \
  --exclude='.mise/logs' \
  --exclude='.mise/state' \
  --exclude='.build' \
  --exclude='.gradle' \
  -C "${PROJECT_DIR}" .

${SCP_CMD} "${TMPTAR}" "${VM_USER}@127.0.0.1:sync.tar.gz"
${SSH_CMD} "if not exist \"${VM_PROJECT_DIR}\" mkdir \"${VM_PROJECT_DIR}\" && cd \"${VM_PROJECT_DIR}\" && tar -xzf \"%USERPROFILE%\\sync.tar.gz\" && del \"%USERPROFILE%\\sync.tar.gz\""
ok "Code synced to ${VM_PROJECT_DIR}"

# ── Step 2: Build inside VM ──────────────────────────────────────────────────

info "Building Tauri Windows app inside VM (this takes a while on first run)..."
${SSH_CMD} "cd \"${VM_PROJECT_DIR}\" && set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && cargo tauri build" \
  || die "Build failed inside VM"
ok "Build complete"

# ── Step 3: Pull artifacts back ──────────────────────────────────────────────

info "Pulling artifacts..."
mkdir -p "${ARTIFACTS_DIR}"

# Get the VM to tar up the bundle dir, scp it back
${SSH_CMD} "cd \"${VM_PROJECT_DIR}\\src-tauri\\target\\release\\bundle\" && tar -czf \"%USERPROFILE%\\artifacts.tar.gz\" ."
${SCP_CMD} "${VM_USER}@127.0.0.1:artifacts.tar.gz" "${ARTIFACTS_DIR}/artifacts.tar.gz"
tar -xzf "${ARTIFACTS_DIR}/artifacts.tar.gz" -C "${ARTIFACTS_DIR}"
rm -f "${ARTIFACTS_DIR}/artifacts.tar.gz"
${SSH_CMD} "del \"%USERPROFILE%\\artifacts.tar.gz\"" 2>/dev/null || true

echo ""
ok "Windows build artifacts in ${ARTIFACTS_DIR}:"
find "${ARTIFACTS_DIR}" \( -name "*.msi" -o -name "*.exe" \) 2>/dev/null | while read -r f; do
  echo "  $(basename "$f") ($(du -h "$f" | awk '{print $1}'))"
done
