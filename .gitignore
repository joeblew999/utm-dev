# Build artifacts (regenerated by build process)
examples/*/.bin/
examples/*/.build/

# Go workspace (local development)
go.work
go.work.sum

# goup-util binaries and bootstrap scripts (build with 'go run . self build')
goup-util-*
macos-bootstrap.sh
windows-bootstrap.ps1

# Source code references (for reading dependencies — cloned repos, gitignored)
.src/*

# Build and distribution directories
.bin/
.build/
.dist/
artifacts/

# Standalone goup-util binary
goup-util
tools/

# Screenshots (generated by robotgo, large files)
# Only commit final curated screenshots manually
docs/screenshots/
screenshot*.png

# Hugo build artifacts
docs/.bin/
docs/.data/
docs/.hugo_build.lock
docs/.hugo-server.log
docs/public/
docs/resources/
docs/themes/

# Local data (UTM VMs, ISOs, screenshots, etc.)
.data/

# Task checksums (generated by go-task)
.task/
*.syso

# Claude Code local session settings
.claude/
